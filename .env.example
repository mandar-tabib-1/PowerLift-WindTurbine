# PowerLift Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control

# NTNU IDUN LLM API Key (required for NTNU provider)
NTNU_API_KEY=your-ntnu-api-key-here
NTNU_API_BASE=https://llm.hpc.ntnu.no/v1

# OpenAI (optional - only if using OpenAI provider)
# OPENAI_API_KEY=your-openai-key

# Anthropic (optional - only if using Anthropic provider)
# ANTHROPIC_API_KEY=your-anthropic-key

# Google (optional - only if using Google provider)
# GOOGLE_API_KEY=your-google-key
